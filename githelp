function devcommit() {
	if [[ -z $1 ]];then
		echo "commit message is needed"
		return
	fi
	git commit -m "DEV: $1"
}


function doccommit() {
        if [[ -z $1 ]];then
                echo "commit message is needed"
                return
        fi
        git commit -m "DOC: $1"
}

